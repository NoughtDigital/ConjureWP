<?xml version="1.0"?>
<ruleset name="WordPress Coding Standards for Plugins">
	<description>Generally-applicable sniffs for WordPress plugins</description>

	<rule ref="WordPress-Core" />
	<rule ref="WordPress-Docs" />
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<exclude-pattern>*/tests/*</exclude-pattern>
		<exclude-pattern>*/examples/*</exclude-pattern>
		<exclude-pattern>*/conjurewp-config.php</exclude-pattern>
		<exclude-pattern>*/includes/class-conjure-freemius.php</exclude-pattern>
		<exclude-pattern>*/uninstall.php</exclude-pattern>
		<exclude name="WordPress.NamingConventions.PrefixAllGlobals.NonPrefixedHooknameFound" />
	</rule>
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="conjurewp"/>
			</property>
		</properties>
	</rule>

	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/dist/*</exclude-pattern>
	<exclude-pattern>*/tests/*</exclude-pattern>
	<exclude-pattern>*/examples/*</exclude-pattern>
	<exclude-pattern>*.min*.js</exclude-pattern>
	<exclude-pattern>*.min*.css</exclude-pattern>
	<exclude-pattern>*/assets/images/spinner.php</exclude-pattern>
</ruleset>
